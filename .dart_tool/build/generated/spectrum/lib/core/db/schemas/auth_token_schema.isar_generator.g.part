    final value = object.refreshToken;
    if (value != null) {
      bytesCount += 3 + value.length * 3;
    }
  }
  bytesCount += 3 + object.service.length * 3;
  return bytesCount;
}

void _authTokenSerialize(
  AuthToken object,
  IsarWriter writer,
  List<int> offsets,
  Map<Type, List<int>> allOffsets,
) {
  writer.writeString(offsets[0], object.accessToken);
  writer.writeDateTime(offsets[1], object.expiresAt);
  writer.writeBool(offsets[2], object.isExpired);
  writer.writeBool(offsets[3], object.needsRefresh);
  writer.writeString(offsets[4], object.refreshToken);
  writer.writeString(offsets[5], object.service);
}

AuthToken _authTokenDeserialize(
  Id id,
  IsarReader reader,
  List<int> offsets,
  Map<Type, List<int>> allOffsets,
) {
  final object = AuthToken();
